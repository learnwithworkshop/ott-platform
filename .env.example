# ========================================
# OTT PLATFORM - SECURITY CONFIGURATION
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ========================================

# Application Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=False

# Security - CRITICAL: Use strong, randomly generated values
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (PostgreSQL - REQUIRED)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://ott_user:strong_password@db:5432/ott_platform
DB_ECHO=False  # Log SQL queries (development only)

# Redis Configuration (REQUIRED for Celery)
# Format: redis://:[password]@host:port/db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# File Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5368709120  # 5GB in bytes

# Password Policy
MIN_PASSWORD_LENGTH=12
REQUIRE_SPECIAL_CHARS=True
REQUIRE_NUMBERS=True
REQUIRE_UPPERCASE=True
REQUIRE_LOWERCASE=True

# ========================================
# PAYMENT INTEGRATION (OPTIONAL)
# ========================================

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Razorpay Configuration (India)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ========================================
# AWS S3 CONFIGURATION (OPTIONAL)
# ========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=ott-videos-bucket
AWS_REGION=us-east-1

# ========================================
# EMAIL CONFIGURATION (OPTIONAL)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password  # Use app-specific password, not account password
EMAILS_ENABLED=False

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO
DATABASE_LOGGING=False  # Log all database queries (development only)
